{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reviewgate.dev/schemas/review-output.schema.json",
  "title": "Review Gate Review Output",
  "type": "object",
  "required": ["score", "target_score", "fail_under", "reviewed_sha", "status", "verdict", "models", "findings", "notes"],
  "additionalProperties": false,
  "allOf": [
    { "if": { "properties": { "fail_under": { "const": 1 } }, "required": ["fail_under"] }, "then": { "properties": { "target_score": { "minimum": 1 } } } },
    { "if": { "properties": { "fail_under": { "const": 2 } }, "required": ["fail_under"] }, "then": { "properties": { "target_score": { "minimum": 2 } } } },
    { "if": { "properties": { "fail_under": { "const": 3 } }, "required": ["fail_under"] }, "then": { "properties": { "target_score": { "minimum": 3 } } } },
    { "if": { "properties": { "fail_under": { "const": 4 } }, "required": ["fail_under"] }, "then": { "properties": { "target_score": { "minimum": 4 } } } },
    { "if": { "properties": { "fail_under": { "const": 5 } }, "required": ["fail_under"] }, "then": { "properties": { "target_score": { "minimum": 5 } } } }
  ],
  "properties": {
    "score": { "type": "integer", "minimum": 0, "maximum": 5 },
    "target_score": { "type": "integer", "minimum": 0, "maximum": 5 },
    "fail_under": { "type": "integer", "minimum": 0, "maximum": 5 },
    "reviewed_sha": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["passed", "needs_changes", "failed"] },
    "verdict": { "type": "string", "minLength": 1 },
    "models": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "estimated_cost_usd": { "type": ["number", "null"], "minimum": 0 },
    "cost_summary": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["current_run_usd", "components"],
      "properties": {
        "current_run_usd": { "type": "number", "minimum": 0 },
        "source": { "type": ["string", "null"], "enum": ["open_router_usage", "fallback_pricing", "unknown", null] },
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/cost_component" }
        }
      }
    },
    "metrics": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "finding_count",
        "blocking_finding_count",
        "inline_eligible_count",
        "p0_count",
        "p1_count",
        "p2_count",
        "p3_count",
        "p4_count",
        "cost_source"
      ],
      "properties": {
        "finding_count": { "type": "integer", "minimum": 0 },
        "blocking_finding_count": { "type": "integer", "minimum": 0 },
        "inline_eligible_count": { "type": "integer", "minimum": 0 },
        "p0_count": { "type": "integer", "minimum": 0 },
        "p1_count": { "type": "integer", "minimum": 0 },
        "p2_count": { "type": "integer", "minimum": 0 },
        "p3_count": { "type": "integer", "minimum": 0 },
        "p4_count": { "type": "integer", "minimum": 0 },
        "current_run_cost_usd": { "type": ["number", "null"], "minimum": 0 },
        "cost_source": { "type": "string", "enum": ["open_router_usage", "fallback_pricing", "unknown"] }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "cost_component": {
      "type": "object",
      "required": ["label", "model", "estimated_cost_usd"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "prompt_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "completion_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "estimated_cost_usd": { "type": "number", "minimum": 0 }
      }
    },
    "finding": {
      "type": "object",
      "required": ["id", "severity", "confidence", "file", "line", "title", "detail", "agent_instruction"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "P4"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "file": { "type": ["string", "null"] },
        "line": { "type": ["integer", "null"], "minimum": 1 },
        "title": { "type": "string", "minLength": 1 },
        "detail": { "type": ["string", "null"] },
        "agent_instruction": { "type": "string", "minLength": 1 }
      }
    }
  }
}
